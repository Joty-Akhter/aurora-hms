# Dev: browser calls http://localhost:3000/api/... (same origin). Vite proxies to VITE_DEV_PROXY_TARGET — no CORS.
# To call the API host directly from the browser instead, set VITE_API_BASE_URL=https://... (remote must allow CORS).
VITE_APP_NAME=Aurora HMS
VITE_API_BASE_URL=http://localhost:3000
VITE_AUTH_SERVICE_URL=http://localhost:8081
VITE_DEV_PROXY_TARGET=http://localhost:8081


