# OS / Editor artifacts
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*~

# Node / Frontend
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Logs & runtime output
logs/
*.log
*.pid
*.seed
tmp/
out/
dist/
build/


# Coverage & test artifacts (root/frontend only — do not use bare `coverage/` or Java packages under `domain/coverage/` are ignored)
/coverage/
frontend/coverage/
*.lcov

# Java / Maven
# Ignore all target directories
target/
**/target/
# Ignore all .class files
*.class
**/*.class
*.jar
# Allow committing the Maven Wrapper binary (otherwise `*.jar` blocks it everywhere)
!**/.mvn/wrapper/maven-wrapper.jar
*.war
*.ear
*.iml
.mvn/timing.properties

# IntelliJ / Eclipse / VS Code
*.classpath
*.project
.settings/
bin/

# Lint / tooling caches
.eslintcache
.stylelintcache
.prettier-cache
.sonar/

